<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= subject %></title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f8f3ea;
        color: #5d5347;
        font-family: "Helvetica Neue", Arial, sans-serif;
      }

      .shell {
        width: 100%;
        background: linear-gradient(180deg, #faf6ef 0%, #f4ede3 100%);
        padding: 36px 16px;
      }

      .card {
        max-width: 640px;
        margin: 0 auto;
        background: #fffdf9;
        border: 1px solid #eee3d4;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 14px 40px rgba(120, 102, 82, 0.08);
      }

      .hero {
        padding: 36px 40px 28px;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.9), transparent 35%),
          linear-gradient(135deg, #f3eadf 0%, #f8f4ec 55%, #fffdf9 100%);
        border-bottom: 1px solid #efe3d3;
      }

      .eyebrow {
        margin: 0 0 12px;
        color: #b79672;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .title {
        margin: 0;
        color: #6b5b4d;
        font-size: 31px;
        line-height: 1.18;
        font-weight: 700;
      }

      .content {
        padding: 40px;
      }

      .greeting,
      .paragraph,
      .secondary,
      .footer {
        margin: 0 0 18px;
        line-height: 1.8;
      }

      .greeting,
      .paragraph {
        color: #5f5448;
        font-size: 16px;
      }

      .button-wrap {
        padding: 8px 0 24px;
      }

      .button {
        display: inline-block;
        padding: 14px 28px;
        background: linear-gradient(135deg, #d9c1a6 0%, #c9a682 100%);
        color: #fffdf9 !important;
        text-decoration: none;
        font-size: 15px;
        font-weight: 700;
        border-radius: 999px;
        box-shadow: 0 10px 24px rgba(201, 166, 130, 0.28);
      }

      .secondary {
        color: #8a7763;
        font-size: 14px;
      }

      .link-box {
        margin-top: 24px;
        padding: 18px 20px;
        background: #f9f5ee;
        border: 1px solid #efe6da;
        border-radius: 18px;
        color: #8b7765;
        font-size: 13px;
        line-height: 1.75;
      }

      .link-box a {
        color: #b48a61;
        word-break: break-all;
      }

      .footer {
        margin-top: 24px;
        color: #a28e78;
        font-size: 13px;
      }

      @media screen and (max-width: 640px) {
        .hero,
        .content {
          padding: 28px 22px;
        }

        .title {
          font-size: 26px;
        }
      }
    </style>
  </head>
  <body>
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0;">
      <%= preheader %>
    </div>

    <div class="shell">
      <div class="card">
        <div class="hero">
          <p class="eyebrow"><%= brandName %></p>
          <h1 class="title"><%= title %></h1>
        </div>

        <div class="content">
          <p class="greeting"><%= greeting %></p>

          <% bodyParagraphs.forEach((paragraph) => { %>
            <p class="paragraph"><%= paragraph %></p>
          <% }) %>

          <div class="button-wrap">
            <a class="button" href="<%= actionUrl %>"><%= actionLabel %></a>
          </div>

          <p class="secondary"><%= secondaryText %></p>

          <div class="link-box">
            Neu nut tren khong hoat dong, hay sao chep lien ket sau vao trinh duyet:
            <br />
            <a href="<%= actionUrl %>"><%= actionUrl %></a>
          </div>

          <p class="footer"><%= footer %></p>
        </div>
      </div>
    </div>
  </body>
</html>
